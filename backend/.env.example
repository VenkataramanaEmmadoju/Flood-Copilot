# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank to allow all in dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
