# ── Frontend (Vite / TanStack Start) ──────────────────────────────────────────
# In development this is empty — the Vite proxy rewrites /api → http://localhost:8000
# In production set this to your deployed backend base URL, e.g.:
#   VITE_API_URL=https://flood-copilot-api.onrender.com/api
VITE_API_URL=

# ── Backend (Express) — see backend/.env.example for the full list ─────────────
# Copy backend/.env.example to backend/.env and fill in the values.
# The only required secret:
GROQ_API_KEY=your_groq_api_key_here
